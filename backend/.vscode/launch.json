{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Backend (Spring Boot)",
      "request": "launch",
      "mainClass": "com.uade.tpejemplo.TpEjemploApplication",
      "projectName": "tpejemplo"
    },
    {
      "type": "node",
      "name": "Frontend (Vite)",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/../frontend",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend (Spring Boot)", "Frontend (Vite)"]
    }
  ]
}
